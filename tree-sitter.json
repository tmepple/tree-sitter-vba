{
  "grammars": [
    {
      "name": "vba",
      "camelCase": "vba",
      "scope": "source.vba",
      "path": ".",
      "file-types": ["bas", "cls", "frm"],
      "injection-regex": "^vba$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for Visual Basic for Applications (VBA)",
    "authors": [
      { "name": "Tim Epple" }
    ],
    "links": {
      "repository": "https://github.com/tmepple/tree-sitter-vba"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
